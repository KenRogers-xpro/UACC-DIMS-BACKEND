generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  password    String
  role        Role       @default(STAFF)
  department  Department
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  documents           Document[]
  procurementRequests ProcurementRequest[] @relation("RequestedBy")
  approvedRequests    ProcurementRequest[] @relation("ApprovedBy")
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]
  registryEntries     RegistryEntry[]
  annotations         Annotation[]

  @@map("users")
}

model Document {
  id          Int              @id @default(autoincrement())
  title       String
  category    DocumentCategory
  department  Department
  filePath    String
  fileSize    Int?
  publicId    String?
  description String?
  uploadedBy  Int
  uploader    User             @relation(fields: [uploadedBy], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("documents")
}

model ProcurementRequest {
  id                 Int               @id @default(autoincrement())
  referenceNo        String            @unique
  itemDescription    String
  quantity           Int
  estimatedCost      Decimal           @db.Decimal(12, 2)
  department         Department
  justification      String
  supportingDocument String?
  status             ProcurementStatus @default(PENDING)
  deptHeadApproval   ApprovalStatus?
  deptHeadComment    String?
  gmApproval         ApprovalStatus?
  gmComment          String?
  requestedById      Int
  requestedBy        User              @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedById       Int?
  approvedBy         User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@map("procurement_requests")
}

model ActivityLog {
  id                  Int        @id @default(autoincrement())
  userId              Int
  user                User       @relation(fields: [userId], references: [id])
  department          Department
  logDate             DateTime
  activityDescription String
  hoursSpent          Float
  createdAt           DateTime   @default(now())

  @@map("activity_logs")
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id])
  action      AuditAction
  module      String
  description String
  ipAddress   String?
  createdAt   DateTime    @default(now())

  @@map("audit_logs")
}

model RegistryEntry {
  id               Int            @id @default(autoincrement())
  registryNo       String         @unique
  subject          String
  docType          DocType
  direction        DocDirection
  source           String
  destination      String
  receivedFrom     String?
  handledById      Int
  handledBy        User           @relation(fields: [handledById], references: [id])
  priority         DocPriority    @default(NORMAL)
  medium           DocMedium
  fileRef          String?
  physicalLocation String?
  status           RegistryStatus @default(PENDING)
  dateRegistered   DateTime
  dateDispatched   DateTime?
  dateReceived     DateTime?
  dateClosed       DateTime?
  annotations      Annotation[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("registry_entries")
}

model Annotation {
  id              Int           @id @default(autoincrement())
  registryEntryId Int
  registryEntry   RegistryEntry @relation(fields: [registryEntryId], references: [id])
  authorId        Int
  author          User          @relation(fields: [authorId], references: [id])
  text            String
  createdAt       DateTime      @default(now())

  @@map("annotations")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  GENERAL_MANAGER
  DEPARTMENT_HEAD
  STAFF
  IT_ADMINISTRATOR
  AUDITOR
  RECORDS_EXECUTIVE
}

enum Department {
  GENERAL_MANAGER_OFFICE
  FINANCE_AND_ADMINISTRATION
  ENGINEERING
  PILOTS
  OPERATIONS
}

enum DocumentCategory {
  POLICY
  REPORT
  MEMO
  CONTRACT
  FORM
  OTHER
}

enum ProcurementStatus {
  PENDING
  DEPT_HEAD_APPROVED
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  APPROVED
  REJECTED
}

enum AuditAction {
  LOGIN
  LOGOUT
  DOCUMENT_UPLOAD
  DOCUMENT_DOWNLOAD
  DOCUMENT_DELETE
  PROCUREMENT_SUBMIT
  PROCUREMENT_APPROVE
  PROCUREMENT_REJECT
  LOG_ENTRY
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
}

enum DocType {
  MEMO
  CONTRACT
  POLICY
  REPORT
  LETTER
  INVOICE
  FORM
  LOGBOOK
  OTHER
}

enum DocDirection {
  INCOMING
  OUTGOING
  INTERNAL
}

enum DocPriority {
  NORMAL
  HIGH
  CONFIDENTIAL
}

enum DocMedium {
  PHYSICAL
  EMAIL
  BOTH
}

enum RegistryStatus {
  PENDING
  DISPATCHED
  RECEIVED
  ACTIONED
  CLOSED
}
