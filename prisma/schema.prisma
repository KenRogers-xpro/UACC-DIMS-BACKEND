generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── CORE ───────────────────────────────────────────────────────────────────

model User {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  password    String
  role        Role       @default(STAFF)
  department  Department
  isActive    Boolean    @default(true)
  signingPinHash   String?   // bcrypt-hashed 4-6 digit signing PIN, separate from login password
  signingPinSetAt  DateTime?
  isLoggedIn  Boolean    @default(false) // set true on login, false on logout — explicit session state,
                                          // decoupled from lastSeenAt so a logout can't be masked by the
                                          // fire-and-forget "last seen" bump every authenticated request gets
  lastSeenAt  DateTime?  // updated on every authenticated request; isOnline is derived from this, not stored
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  documents           Document[]
  procurementRequests ProcurementRequest[] @relation("RequestedBy")
  approvedRequests    ProcurementRequest[] @relation("ApprovedBy")
  poProcessedRequests ProcurementRequest[] @relation("POProcessedBy")
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]
  registryEntries     RegistryEntry[]
  annotations         Annotation[]
  scheduleEvents      GMScheduleEvent[]      @relation("ScheduleCreator")
  draftDocuments      DraftDocument[]        @relation("DraftAuthor")
  circulationsOriginated DocumentCirculation[] @relation("CirculationOriginator")
  circulationStepsFrom   CirculationStep[]     @relation("StepFrom")
  recordsFiled           CirculationRecordsCopy[]
  awaitingCorrections    DocumentCirculation[] @relation("AwaitingCorrection")

  documentVersions    DocumentVersion[]
  signatures          DigitalSignature[]
  recordsFilesCreated RecordsFile[]
  dispatchedRecords   DispatchRecord[]        @relation("DispatchedBy")
  messagesSent        DirectMessage[]         @relation("MessageSender")
  messagesReceived    DirectMessage[]         @relation("MessageRecipient")
  announcements       Announcement[]
  notificationReads   NotificationRead[]
  hiddenConversations HiddenConversation[]
  circulationAttachmentsMade CirculationAttachment[]
  unansweredQueries   UnansweredQuery[]
  agentInsights       AgentInsight[]

  @@map("users")
}

model Document {
  id          Int              @id @default(autoincrement())
  title       String
  category    DocumentCategory
  department  Department
  filePath    String           // Cloudinary secure_url for uploads going forward; "draft://<id>" placeholder for finalized drafts; legacy rows may still have just the original filename here (see fileData)
  fileSize    Int?
  fileData    Bytes?           // legacy: file content stored directly in Postgres — null for anything uploaded through Cloudinary or draft-originated
  publicId    String?          // Cloudinary public_id, needed for delete/signed-url/info lookups — null for legacy fileData-backed rows and drafts
  mimeType    String?
  description String?
  status      String           @default("PRIVATE") // PRIVATE, SUBMITTED, IN_CIRCULATION, FINALIZED
  isEditable  Boolean          @default(true)       // false once submitted/circulated —
                                                     // ties into the immutability rule from circulation
  uploadedBy  Int
  uploader    User             @relation(fields: [uploadedBy], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  annotations Annotation[]
  versions    DocumentVersion[]
  registryEntries RegistryEntry[]
  circulationAttachments CirculationAttachment[]

  @@map("documents")
}

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    Int
  document      Document @relation(fields: [documentId], references: [id])
  versionNumber Int
  fileUrl       String
  filePublicId  String
  uploadedById  Int
  uploadedBy    User     @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([documentId])
}

model ProcurementRequest {
  id                 Int               @id @default(autoincrement())
  referenceNo        String            @unique
  itemDescription    String
  quantity           Int
  estimatedCost      Decimal           @db.Decimal(12, 2)
  department         Department
  justification      String
  supportingDocument String?
  status             ProcurementStatus @default(PENDING_DEPT_HEAD)
  deptHeadApproval   ApprovalStatus?
  deptHeadComment    String?
  vendorName         String?
  vendorVerified     Boolean           @default(false)
  budgetVerified     Boolean           @default(false)
  poNotes            String?
  poProcessedById    Int?
  poProcessedBy      User?             @relation("POProcessedBy", fields: [poProcessedById], references: [id])
  poProcessedAt      DateTime?
  gmApproval         ApprovalStatus?
  gmComment          String?
  requestedById      Int
  requestedBy        User              @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedById       Int?
  approvedBy         User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@map("procurement_requests")
}

model ActivityLog {
  id                  Int        @id @default(autoincrement())
  userId              Int
  user                User       @relation(fields: [userId], references: [id])
  department          Department
  logDate             DateTime
  activityDescription String
  hoursSpent          Float
  createdAt           DateTime   @default(now())

  @@map("activity_logs")
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id])
  action      AuditAction
  module      String
  description String
  ipAddress   String?
  createdAt   DateTime    @default(now())

  @@map("audit_logs")
}

// ─── RECORDS REGISTRY & FILING ──────────────────────────────────────────────

model RegistryEntry {
  id               Int                @id @default(autoincrement())
  registryNo       String             @unique
  subject          String
  docType          DocType
  direction        DocDirection
  source           String
  destination      String
  receivedFrom     String?
  handledById      Int
  handledBy        User               @relation(fields: [handledById], references: [id])
  priority         DocPriority        @default(NORMAL)
  medium           DocMedium
  fileRef          String?
  physicalLocation String?
  status           RegistryStatus     @default(PENDING)
  confidentiality  DocConfidentiality @default(INTERNAL)

  // Records governance / compliance tracking
  retentionPeriodMonths Int?      // how long this record must be retained; null = indefinite
  retentionExpiresAt    DateTime? // computed as dateRegistered + retentionPeriodMonths

  // Entity-file / dossier linkage — Records Executive's discretion, nullable
  recordsFileId    String?
  recordsFile      RecordsFile?   @relation(fields: [recordsFileId], references: [id])

  // Bridge: registry entries auto-created from an uploaded Document (see
  // documents.routes.js POST / and POST /:id/submit), nullable since manually
  // registered physical/email correspondence has no source Document.
  sourceDocumentId Int?
  sourceDocument   Document?      @relation(fields: [sourceDocumentId], references: [id])

  dateRegistered   DateTime
  dateDispatched   DateTime?
  dateReceived     DateTime?
  dateClosed       DateTime?
  annotations      Annotation[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("registry_entries")
}

// Freeform, Records-Executive-controlled dossier. Not a fixed taxonomy —
// RE decides what folders exist (personal files, officer files, asset files, etc).
// No delete route exists for this model. TRIPWIRE for whoever adds one:
// deletion must check entries.length === 0 AND filedCopies.length === 0 first
// — a dossier with either is part of the permanent record, same rule as
// documents.routes.js DELETE /:id for Document + circulation history.
model RecordsFile {
  id            String   @id @default(cuid())
  fileNumber    String   @unique
  title         String
  fileType      String?  // free text label, RE's own categorization
  description   String?
  status        String   @default("ACTIVE") // ACTIVE, ARCHIVED, CLOSED
  createdById   Int
  createdBy     User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entries       RegistryEntry[]
  filedCopies   CirculationRecordsCopy[]

  @@index([fileNumber])
}

model Annotation {
  id              Int            @id @default(autoincrement())
  registryEntryId Int?
  registryEntry   RegistryEntry? @relation(fields: [registryEntryId], references: [id])
  documentId      Int?
  document        Document?      @relation(fields: [documentId], references: [id])
  authorId        Int
  author          User           @relation(fields: [authorId], references: [id])
  type            String         @default("COMMENT") // COMMENT, NOTE, ACTION, FLAG
  text            String
  ccRoles         String[]       @default([]) // informed-only roles, grants view access same as circulation CC
  createdAt       DateTime       @default(now())

  // Application layer must enforce: exactly one of registryEntryId / documentId is set.
  @@map("annotations")
}

// Semantic search embeddings (pgvector). Prisma cannot manage the vector column
// type directly — the `vector(768)` column and pgvector extension must be created
// via raw SQL migration (CREATE EXTENSION IF NOT EXISTS vector; then ALTER TABLE
// ADD COLUMN embedding vector(768);). 768 dimensions matches gemini-embedding-001.
model DocumentEmbedding {
  id               String   @id @default(cuid())
  sourceType       String   // "DOCUMENT", "REGISTRY_ENTRY", "CIRCULATION_STEP", "DRAFT_DOCUMENT"
  sourceId         String   // polymorphic — stores the source record's ID as text regardless
                        // of whether the source table uses Int or String primary keys
  chunkIndex       Int
  chunkText        String   @db.Text
  embedding        Unsupported("vector(768)")
  bodyExtracted    Boolean  @default(false)
  extractionMethod String?
  createdAt        DateTime @default(now())

  @@index([sourceType, sourceId])
}

// ─── AI AGENT INSIGHTS ──────────────────────────────────────────────────────
// A question the AI agent couldn't answer well gets stored with its own
// embedding; every later document ingestion checks unresolved questions
// against just the new chunks, and a strong-enough match produces an
// AgentInsight for whoever asked. Same pgvector-needs-raw-SQL caveat as
// DocumentEmbedding above.

model UnansweredQuery {
  id             String    @id @default(cuid())
  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  queryText      String    @db.Text
  embedding      Unsupported("vector(768)")
  bestScoreAtAsk Float?    // best similarity at time of asking, for reference/tuning
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId, resolvedAt])
}

model AgentInsight {
  id          String    @id @default(cuid())
  userId      Int       // who this insight is FOR
  user        User      @relation(fields: [userId], references: [id])
  queryId     String?   // the UnansweredQuery it resolves, if any
  title       String
  body        String    @db.Text
  sourceType  String    // "DOCUMENT", "REGISTRY_ENTRY", etc.
  sourceId    String
  similarity  Float
  seenAt      DateTime?
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, seenAt, dismissedAt])
}

// ─── DIGITAL SIGNATURES ─────────────────────────────────────────────────────

model DigitalSignature {
  id                   String   @id @default(cuid())
  circulationStepId    String?  @unique
  circulationStep      CirculationStep? @relation(fields: [circulationStepId], references: [id])
  signerId             Int
  signer               User     @relation(fields: [signerId], references: [id])
  signerRole           String   // role AT TIME of signing, captured explicitly
  decision             String
  verifiedWithPin      Boolean  @default(false)
  verifiedWithPassword Boolean  @default(false) // true only for high-stakes actions
  previousHash         String?  // hash of the prior signature in this document's chain
  signatureHash        String   // SHA-256 of (signerId + decision + timestamp + previousHash)
  supersededAt         DateTime? // set when the underlying document is corrected/resubmitted
  ipAddress            String?
  signedAt             DateTime @default(now())

  @@index([signerId])
}

// ─── SCHEDULING (GM / PA) ───────────────────────────────────────────────────

model GMScheduleEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  createdById Int
  createdBy   User     @relation("ScheduleCreator", fields: [createdById], references: [id])
  status      String   @default("CONFIRMED") // CONFIRMED, TENTATIVE, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── DOCUMENT CIRCULATION ───────────────────────────────────────────────────

model DocumentCirculation {
  id                String   @id @default(cuid())
  title             String
  sourceType        String?  // "DOCUMENT", "REGISTRY_ENTRY", "PROCUREMENT_REQUEST", "STANDALONE_MEMO"
  sourceId          String?
  originatorId      Int
  originator        User     @relation("CirculationOriginator", fields: [originatorId], references: [id])
  currentHolderRole String   // whoever currently "has" the document, e.g. "GENERAL_MANAGER"
  status            String   @default("IN_CIRCULATION") // IN_CIRCULATION, CLOSED

  // Immutability / correction handling
  awaitingCorrectionFrom Int?
  awaitingCorrectionUser User? @relation("AwaitingCorrection", fields: [awaitingCorrectionFrom], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  steps             CirculationStep[]
  dispatchRecord    DispatchRecord?
  attachments       CirculationAttachment[]
  recordsCopy       CirculationRecordsCopy?
}

model CirculationAttachment {
  id                String   @id @default(cuid())
  circulationId     String
  circulation       DocumentCirculation @relation(fields: [circulationId], references: [id])
  circulationStepId String?  // which step it was attached at, for the trail
  documentId        Int      // every attachment IS a real Document record
  document          Document @relation(fields: [documentId], references: [id])
  attachedById      Int
  attachedBy        User     @relation(fields: [attachedById], references: [id])
  note              String?  // e.g. "Quotation from UPPC as requested"
  createdAt         DateTime @default(now())
}

model CirculationStep {
  id              String   @id @default(cuid())
  circulationId   String
  circulation     DocumentCirculation @relation(fields: [circulationId], references: [id])
  stepNumber      Int      // sequential: 1, 2, 3... matches the paper's I, II, III numbering
  fromUserId      Int
  fromUser        User     @relation("StepFrom", fields: [fromUserId], references: [id])
  fromRole        String
  toUserId        Int?     // nullable if routed to a role generally, not a specific person
  toRole          String
  heldByRole      String?  // who must ACTUALLY act on this step right now — defaults
                            // to toRole (normal case). When GM-gatekeeping applies,
                            // this is GM_PERSONAL_ASSISTANT instead, while toRole stays
                            // whatever the sender declared (e.g. GENERAL_MANAGER).
                            // DocumentCirculation.currentHolderRole is always derived
                            // from this field, never from toRole directly.
  ccRoles         String[] @default([]) // informed-only roles — never granted currentHolderRole, never actionable
  instruction     String   @db.Text // the annotation text, e.g. "Please verify"
  stepType        String   // FORWARD, VERIFICATION_REQUEST, VERIFICATION_RESPONSE,
                            // APPROVAL, FINAL_DECISION, RETURNED_FOR_CORRECTION, RESUBMITTED
  decision        String?  // e.g. "NO_OBJECTION", "APPROVED", "REJECTED"
  amount          Decimal? // for financial approvals
  signedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  recordsCopies   CirculationRecordsCopy[]
  signature       DigitalSignature?
}

// One package per CLOSED circulation, created explicitly via
// POST /api/circulation/:id/send-to-file — never auto-created on a step or
// signature anymore (see circulation.routes.js). circulationId is the real
// link the Filing Queue resolves the document + full step trail through;
// circulationStepId is kept only as "the closing step, for reference" and
// is no longer what creates this row.
model CirculationRecordsCopy {
  id                String    @id @default(cuid())
  circulationId     String    @unique
  circulation       DocumentCirculation @relation(fields: [circulationId], references: [id])
  circulationStepId String?
  step              CirculationStep? @relation(fields: [circulationStepId], references: [id])
  status            String    @default("PENDING_FILING") // PENDING_FILING, FILED

  // Optional dossier this copy was filed into — set at filing time via the
  // Filing Queue's own file picker, same RecordsFile the register modal
  // links to.
  recordsFileId     String?
  recordsFile       RecordsFile? @relation(fields: [recordsFileId], references: [id])

  filedById         Int?
  filedBy           User?     @relation(fields: [filedById], references: [id])
  filedAt           DateTime?
  createdAt         DateTime  @default(now())
}

// ─── DISPATCH (outgoing, external) ──────────────────────────────────────────

model DispatchRecord {
  id                     String    @id @default(cuid())
  dispatchNumber         String    @unique
  circulationId          String    @unique
  circulation            DocumentCirculation @relation(fields: [circulationId], references: [id])
  recipientName          String
  recipientOrganization  String?
  recipientAddress       String?
  recipientEmail         String?
  dispatchMethod         String    // POST, COURIER, EMAIL, HAND_DELIVERY
  dispatchedById         Int
  dispatchedBy           User      @relation("DispatchedBy", fields: [dispatchedById], references: [id])
  dispatchedAt           DateTime  @default(now())
  status                 String    @default("DISPATCHED") // DISPATCHED, DELIVERED, ACKNOWLEDGED, RETURNED, LOST
  proofOfDeliveryUrl     String?
  acknowledgedAt         DateTime?
  acknowledgedBy         String?   // free text — external signatory, not a User FK
  trackingReference      String?
  notes                  String?   @db.Text
  createdAt              DateTime  @default(now())
}

// ─── DRAFTS (PA drafting on behalf of GM) ───────────────────────────────────

model DraftDocument {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  origin      String   @default("HUMAN") // "HUMAN" or "AI_GENERATED"
  reviewedAt  DateTime?
  draftedById Int
  draftedBy   User     @relation("DraftAuthor", fields: [draftedById], references: [id])
  status      String   @default("DRAFT") // DRAFT, PENDING_GM_REVIEW, GM_APPROVED, GM_REJECTED, FINALIZED
  gmFeedback  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── INTERNAL COMMUNICATIONS ────────────────────────────────────────────────

model DirectMessage {
  id          String    @id @default(cuid())
  senderId    Int
  sender      User      @relation("MessageSender", fields: [senderId], references: [id])
  recipientId Int
  recipient   User      @relation("MessageRecipient", fields: [recipientId], references: [id])
  content     String    @db.Text
  readAt      DateTime?
  editedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([senderId, recipientId])
  @@index([recipientId, readAt])
}

// Conversations aren't a first-class row (they're derived by grouping
// DirectMessage by partner), so "delete conversation" can't be a delete at
// all without destroying the other party's copy too — it's a per-user
// visibility flag instead. A conversation with activity newer than hiddenAt
// (a message sent OR received after hiding) is no longer filtered out; see
// GET /api/messages/conversations.
model HiddenConversation {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  otherUserId Int
  hiddenAt    DateTime @default(now())

  @@unique([userId, otherUserId])
}

model Announcement {
  id        String    @id @default(cuid())
  authorId  Int
  author    User      @relation(fields: [authorId], references: [id])
  title     String
  content   String    @db.Text
  pinned    Boolean   @default(false)
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
}

// ─── NOTIFICATION READ STATE ─────────────────────────────────────────────────
// Real per-user read-tracking for notification-bell items that have no
// native read state of their own (circulation steps, announcements —
// DirectMessage already has readAt and keeps using that). Replaces the
// earlier 72h-lookback-window workaround for announcements.

model NotificationRead {
  id         String   @id @default(cuid())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  sourceType String   // "CIRCULATION_STEP", "MESSAGE", "ANNOUNCEMENT"
  sourceId   String
  readAt     DateTime @default(now())

  @@unique([userId, sourceType, sourceId])
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  GENERAL_MANAGER
  GM_PERSONAL_ASSISTANT
  DEPARTMENT_HEAD
  STAFF
  IT_ADMINISTRATOR
  INTERNAL_AUDITOR
  RECORDS_EXECUTIVE
  PROCUREMENT_OFFICER
  HR_MANAGER
  FINANCE_DIRECTOR
  MARKETING_OFFICER
  CORPORATION_SECRETARY
}

enum Department {
  GENERAL_MANAGER_OFFICE
  FINANCE_AND_ADMINISTRATION
  ENGINEERING
  PILOTS
  OPERATIONS
  HUMAN_RESOURCES
  FINANCE_AND_ACCOUNTS
  MARKETING
}

enum DocumentCategory {
  POLICY
  REPORT
  MEMO
  CONTRACT
  FORM
  OTHER
}

enum ProcurementStatus {
  PENDING_DEPT_HEAD
  PENDING_PROCUREMENT_OFFICER
  PENDING_GM
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  APPROVED
  REJECTED
}

enum AuditAction {
  LOGIN
  LOGOUT
  DOCUMENT_UPLOAD
  DOCUMENT_DOWNLOAD
  DOCUMENT_DELETE
  PROCUREMENT_SUBMIT
  PROCUREMENT_VENDOR_VERIFIED
  PROCUREMENT_APPROVE
  PROCUREMENT_REJECT
  PA_TRIAGED_DOCUMENT
  PA_SENT_GM_COMMUNICATION
  DRAFT_CREATED
  DRAFT_SUBMITTED
  DRAFT_REVIEWED
  DRAFT_FINALIZED
  LOG_ENTRY
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  REGISTRY_ENTRY_CREATED
  REGISTRY_ENTRY_UPDATED
  REGISTRY_ENTRY_DELETED
  ANNOTATION_ADDED
  ANNOTATION_DELETED
  RECORDS_FILE_CREATED
  ENTRY_ATTACHED_TO_FILE
  ENTRY_DETACHED_FROM_FILE
  CIRCULATION_INITIATED
  CIRCULATION_STEP_ADDED
  DOCUMENT_RETURNED_FOR_CORRECTION
  DOCUMENT_RESUBMITTED
  SIGNATURE_CREATED
  SIGNING_PIN_SET
  SIGNING_PIN_CHANGED
  DISPATCH_CREATED
  DISPATCH_ACKNOWLEDGED
  DISPATCH_STATUS_UPDATED
  SCHEDULE_EVENT_CREATED
  SCHEDULE_EVENT_UPDATED
  SCHEDULE_EVENT_CANCELLED
  MESSAGE_SENT
  ANNOUNCEMENT_CREATED
  ANNOUNCEMENT_DELETED
}

enum DocType {
  MEMO
  CONTRACT
  POLICY
  REPORT
  LETTER
  INVOICE
  FORM
  LOGBOOK
  OTHER
}

enum DocDirection {
  INCOMING
  OUTGOING
  INTERNAL
}

enum DocPriority {
  NORMAL
  HIGH
  CONFIDENTIAL
}

enum DocMedium {
  PHYSICAL
  EMAIL
  BOTH
}

enum DocConfidentiality {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum RegistryStatus {
  PENDING
  DISPATCHED
  RECEIVED
  ACTIONED
  CLOSED
}
