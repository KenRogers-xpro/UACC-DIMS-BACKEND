generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  password    String
  role        Role       @default(STAFF)
  department  Department
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  documents           Document[]
  procurementRequests ProcurementRequest[] @relation("RequestedBy")
  approvedRequests    ProcurementRequest[] @relation("ApprovedBy")
  poProcessedRequests ProcurementRequest[] @relation("POProcessedBy")
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]
  registryEntries     RegistryEntry[]
  annotations         Annotation[]
  scheduleEvents      GMScheduleEvent[]      @relation("ScheduleCreator")
  documentRoutings    DocumentRouting[]      @relation("DocumentTriager")
  draftDocuments      DraftDocument[]        @relation("DraftAuthor")

  @@map("users")
}

model Document {
  id          Int              @id @default(autoincrement())
  title       String
  category    DocumentCategory
  department  Department
  filePath    String
  fileSize    Int?
  publicId    String?
  description String?
  uploadedBy  Int
  uploader    User             @relation(fields: [uploadedBy], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("documents")
}

model ProcurementRequest {
  id                 Int               @id @default(autoincrement())
  referenceNo        String            @unique
  itemDescription    String
  quantity           Int
  estimatedCost      Decimal           @db.Decimal(12, 2)
  department         Department
  justification      String
  supportingDocument String?
  status             ProcurementStatus @default(PENDING_DEPT_HEAD)
  deptHeadApproval   ApprovalStatus?
  deptHeadComment    String?
  vendorName         String?
  vendorVerified     Boolean           @default(false)
  budgetVerified     Boolean           @default(false)
  poNotes            String?
  poProcessedById    Int?
  poProcessedBy      User?             @relation("POProcessedBy", fields: [poProcessedById], references: [id])
  poProcessedAt      DateTime?
  gmApproval         ApprovalStatus?
  gmComment          String?
  requestedById      Int
  requestedBy        User              @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedById       Int?
  approvedBy         User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@map("procurement_requests")
}

model ActivityLog {
  id                  Int        @id @default(autoincrement())
  userId              Int
  user                User       @relation(fields: [userId], references: [id])
  department          Department
  logDate             DateTime
  activityDescription String
  hoursSpent          Float
  createdAt           DateTime   @default(now())

  @@map("activity_logs")
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id])
  action      AuditAction
  module      String
  description String
  ipAddress   String?
  createdAt   DateTime    @default(now())

  @@map("audit_logs")
}

model RegistryEntry {
  id               Int            @id @default(autoincrement())
  registryNo       String         @unique
  subject          String
  docType          DocType
  direction        DocDirection
  source           String
  destination      String
  receivedFrom     String?
  handledById      Int
  handledBy        User           @relation(fields: [handledById], references: [id])
  priority         DocPriority    @default(NORMAL)
  medium           DocMedium
  fileRef          String?
  physicalLocation String?
  status           RegistryStatus @default(PENDING)
  dateRegistered   DateTime
  dateDispatched   DateTime?
  dateReceived     DateTime?
  dateClosed       DateTime?
  annotations      Annotation[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("registry_entries")
}

model Annotation {
  id              Int           @id @default(autoincrement())
  registryEntryId Int
  registryEntry   RegistryEntry @relation(fields: [registryEntryId], references: [id])
  authorId        Int
  author          User          @relation(fields: [authorId], references: [id])
  text            String
  createdAt       DateTime      @default(now())

  @@map("annotations")
}

model GMScheduleEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  createdById Int
  createdBy   User     @relation("ScheduleCreator", fields: [createdById], references: [id])
  status      String   @default("CONFIRMED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DocumentRouting {
  id          String   @id @default(cuid())
  sourceType  String
  sourceId    String
  addressedTo String   @default("GENERAL_MANAGER")
  triagedById Int?
  triagedBy   User?    @relation("DocumentTriager", fields: [triagedById], references: [id])
  priority    String   @default("NORMAL")
  paNote      String?
  status      String   @default("PENDING_TRIAGE")
  createdAt   DateTime @default(now())
  forwardedAt DateTime?
}

model DraftDocument {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  draftedById Int
  draftedBy  User     @relation("DraftAuthor", fields: [draftedById], references: [id])
  status     String   @default("DRAFT")
  gmFeedback String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  GENERAL_MANAGER
  GM_PERSONAL_ASSISTANT
  DEPARTMENT_HEAD
  STAFF
  IT_ADMINISTRATOR
  INTERNAL_AUDITOR
  RECORDS_EXECUTIVE
  PROCUREMENT_OFFICER
  HR_MANAGER
  FINANCE_DIRECTOR
  ACCOUNTS_OFFICER
  MARKETING_OFFICER
}

enum Department {
  GENERAL_MANAGER_OFFICE
  FINANCE_AND_ADMINISTRATION
  ENGINEERING
  PILOTS
  OPERATIONS
  HUMAN_RESOURCES
  FINANCE_AND_ACCOUNTS
  MARKETING
}

enum DocumentCategory {
  POLICY
  REPORT
  MEMO
  CONTRACT
  FORM
  OTHER
}

enum ProcurementStatus {
  PENDING_DEPT_HEAD
  PENDING_PROCUREMENT_OFFICER
  PENDING_GM
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  APPROVED
  REJECTED
}

enum AuditAction {
  LOGIN
  LOGOUT
  DOCUMENT_UPLOAD
  DOCUMENT_DOWNLOAD
  DOCUMENT_DELETE
  PROCUREMENT_SUBMIT
  PROCUREMENT_VENDOR_VERIFIED
  PROCUREMENT_APPROVE
  PROCUREMENT_REJECT
  PA_TRIAGED_DOCUMENT
  DRAFT_CREATED
  DRAFT_SUBMITTED
  DRAFT_REVIEWED
  DRAFT_FINALIZED
  LOG_ENTRY
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
}

enum DocType {
  MEMO
  CONTRACT
  POLICY
  REPORT
  LETTER
  INVOICE
  FORM
  LOGBOOK
  OTHER
}

enum DocDirection {
  INCOMING
  OUTGOING
  INTERNAL
}

enum DocPriority {
  NORMAL
  HIGH
  CONFIDENTIAL
}

enum DocMedium {
  PHYSICAL
  EMAIL
  BOTH
}

enum RegistryStatus {
  PENDING
  DISPATCHED
  RECEIVED
  ACTIONED
  CLOSED
}
