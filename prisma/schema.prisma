generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  password    String
  role        Role       @default(STAFF)
  department  Department
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  documents           Document[]
  procurementRequests ProcurementRequest[] @relation("RequestedBy")
  approvedRequests    ProcurementRequest[] @relation("ApprovedBy")
  poProcessedRequests ProcurementRequest[] @relation("POProcessedBy")
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]
  registryEntries     RegistryEntry[]
  annotations         Annotation[]
  scheduleEvents      GMScheduleEvent[]      @relation("ScheduleCreator")
  draftDocuments      DraftDocument[]        @relation("DraftAuthor")
  circulationsOriginated DocumentCirculation[] @relation("CirculationOriginator")
  circulationStepsFrom   CirculationStep[]     @relation("StepFrom")
  recordsFiled           CirculationRecordsCopy[]

  @@map("users")
}

model Document {
  id          Int              @id @default(autoincrement())
  title       String
  category    DocumentCategory
  department  Department
  filePath    String
  fileSize    Int?
  publicId    String?
  description String?
  uploadedBy  Int
  uploader    User             @relation(fields: [uploadedBy], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("documents")
}

model ProcurementRequest {
  id                 Int               @id @default(autoincrement())
  referenceNo        String            @unique
  itemDescription    String
  quantity           Int
  estimatedCost      Decimal           @db.Decimal(12, 2)
  department         Department
  justification      String
  supportingDocument String?
  status             ProcurementStatus @default(PENDING_DEPT_HEAD)
  deptHeadApproval   ApprovalStatus?
  deptHeadComment    String?
  vendorName         String?
  vendorVerified     Boolean           @default(false)
  budgetVerified     Boolean           @default(false)
  poNotes            String?
  poProcessedById    Int?
  poProcessedBy      User?             @relation("POProcessedBy", fields: [poProcessedById], references: [id])
  poProcessedAt      DateTime?
  gmApproval         ApprovalStatus?
  gmComment          String?
  requestedById      Int
  requestedBy        User              @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedById       Int?
  approvedBy         User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@map("procurement_requests")
}

model ActivityLog {
  id                  Int        @id @default(autoincrement())
  userId              Int
  user                User       @relation(fields: [userId], references: [id])
  department          Department
  logDate             DateTime
  activityDescription String
  hoursSpent          Float
  createdAt           DateTime   @default(now())

  @@map("activity_logs")
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id])
  action      AuditAction
  module      String
  description String
  ipAddress   String?
  createdAt   DateTime    @default(now())

  @@map("audit_logs")
}

model RegistryEntry {
  id               Int            @id @default(autoincrement())
  registryNo       String         @unique
  subject          String
  docType          DocType
  direction        DocDirection
  source           String
  destination      String
  receivedFrom     String?
  handledById      Int
  handledBy        User           @relation(fields: [handledById], references: [id])
  priority         DocPriority    @default(NORMAL)
  medium           DocMedium
  fileRef          String?
  physicalLocation String?
  status           RegistryStatus @default(PENDING)
  dateRegistered   DateTime
  dateDispatched   DateTime?
  dateReceived     DateTime?
  dateClosed       DateTime?
  annotations      Annotation[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("registry_entries")
}

model Annotation {
  id              Int           @id @default(autoincrement())
  registryEntryId Int
  registryEntry   RegistryEntry @relation(fields: [registryEntryId], references: [id])
  authorId        Int
  author          User          @relation(fields: [authorId], references: [id])
  text            String
  createdAt       DateTime      @default(now())

  @@map("annotations")
}

model GMScheduleEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  createdById Int
  createdBy   User     @relation("ScheduleCreator", fields: [createdById], references: [id])
  status      String   @default("CONFIRMED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DocumentCirculation {
  id               String   @id @default(cuid())
  title            String
  sourceType       String?  // "DOCUMENT", "REGISTRY_ENTRY", "PROCUREMENT_REQUEST", 
                              // "STANDALONE_MEMO" — nullable for memos with no 
                              // pre-existing system record
  sourceId         String?
  originatorId     Int
  originator       User     @relation("CirculationOriginator", fields: [originatorId], references: [id])
  currentHolderRole String  // whoever currently "has" the document, e.g. "GENERAL_MANAGER"
  status           String   @default("IN_CIRCULATION") // IN_CIRCULATION, CLOSED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  steps            CirculationStep[]
}

model CirculationStep {
  id              String   @id @default(cuid())
  circulationId   String
  circulation     DocumentCirculation @relation(fields: [circulationId], references: [id])
  stepNumber      Int      // sequential: 1, 2, 3... matches the paper's I, II, III numbering
  fromUserId      Int
  fromUser        User     @relation("StepFrom", fields: [fromUserId], references: [id])
  fromRole        String
  toUserId        Int?     // nullable if routed to a role generally, not a specific person
  toRole          String
  instruction     String   @db.Text // the annotation text, e.g. "Please verify"
  stepType        String   // FORWARD, VERIFICATION_REQUEST, VERIFICATION_RESPONSE, 
                             // APPROVAL, FINAL_DECISION
  decision        String?  // e.g. "NO_OBJECTION", "APPROVED", "REJECTED" — nullable
  amount          Decimal? // for financial approvals, e.g. the USD 3,500 in your example
  signedAt        DateTime @default(now()) // digital equivalent of the handwritten 
                                             // signature + date, tied to authenticated user
  createdAt       DateTime @default(now())
  recordsCopies   CirculationRecordsCopy[]
}

model CirculationRecordsCopy {
  id                String   @id @default(cuid())
  circulationStepId String
  step              CirculationStep @relation(fields: [circulationStepId], references: [id])
  status            String   @default("PENDING_FILING") // PENDING_FILING, FILED
  filedById         Int?
  filedBy           User?    @relation(fields: [filedById], references: [id])
  filedAt           DateTime?
  createdAt         DateTime @default(now())
}

model DraftDocument {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  draftedById Int
  draftedBy  User     @relation("DraftAuthor", fields: [draftedById], references: [id])
  status     String   @default("DRAFT")
  gmFeedback String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  GENERAL_MANAGER
  GM_PERSONAL_ASSISTANT
  DEPARTMENT_HEAD
  STAFF
  IT_ADMINISTRATOR
  INTERNAL_AUDITOR
  RECORDS_EXECUTIVE
  PROCUREMENT_OFFICER
  HR_MANAGER
  FINANCE_DIRECTOR
  ACCOUNTS_OFFICER
  MARKETING_OFFICER
}

enum Department {
  GENERAL_MANAGER_OFFICE
  FINANCE_AND_ADMINISTRATION
  ENGINEERING
  PILOTS
  OPERATIONS
  HUMAN_RESOURCES
  FINANCE_AND_ACCOUNTS
  MARKETING
}

enum DocumentCategory {
  POLICY
  REPORT
  MEMO
  CONTRACT
  FORM
  OTHER
}

enum ProcurementStatus {
  PENDING_DEPT_HEAD
  PENDING_PROCUREMENT_OFFICER
  PENDING_GM
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  APPROVED
  REJECTED
}

enum AuditAction {
  LOGIN
  LOGOUT
  DOCUMENT_UPLOAD
  DOCUMENT_DOWNLOAD
  DOCUMENT_DELETE
  PROCUREMENT_SUBMIT
  PROCUREMENT_VENDOR_VERIFIED
  PROCUREMENT_APPROVE
  PROCUREMENT_REJECT
  PA_TRIAGED_DOCUMENT
  DRAFT_CREATED
  DRAFT_SUBMITTED
  DRAFT_REVIEWED
  DRAFT_FINALIZED
  LOG_ENTRY
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
}

enum DocType {
  MEMO
  CONTRACT
  POLICY
  REPORT
  LETTER
  INVOICE
  FORM
  LOGBOOK
  OTHER
}

enum DocDirection {
  INCOMING
  OUTGOING
  INTERNAL
}

enum DocPriority {
  NORMAL
  HIGH
  CONFIDENTIAL
}

enum DocMedium {
  PHYSICAL
  EMAIL
  BOTH
}

enum RegistryStatus {
  PENDING
  DISPATCHED
  RECEIVED
  ACTIONED
  CLOSED
}
