# PostgreSQL — Neon
DATABASE_URL="postgresql://username:password@ep-xxx.eu-west-1.aws.neon.tech/uacc-dims?sslmode=require"

# JWT Authentication
JWT_SECRET="uacc-dims-jwt-secret-2026-nkumba-university-very-long-string"
JWT_EXPIRES_IN="7d"

# Google Gemini AI
GEMINI_API_KEY="AIza-your-key-here"
AI_PROVIDER="gemini"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Resend Email
RESEND_API_KEY="re_your-key-here"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"